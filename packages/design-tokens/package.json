{
  "name": "@hollis/design-tokens",
  "version": "1.0.0",
  "private": true,
  "main": "./index.ts",
  "types": "./index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./index.ts",
      "default": "./index.ts"
    },
    "./tokens": {
      "types": "./tokens/index.ts",
      "default": "./tokens/index.ts"
    },
    "./tokens/*": {
      "types": "./tokens/*.ts",
      "default": "./tokens/*.ts"
    },
    "./native": {
      "types": "./native/index.ts",
      "default": "./native/index.ts"
    },
    "./web": {
      "types": "./web/index.ts",
      "default": "./web/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate:css": "npx tsx scripts/generate-css-variables.ts",
    "build": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.3.0"
  }
}
